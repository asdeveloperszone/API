# ─────────────────────────────────────────────────────────────────────────────
# ASDroid TikTok API – Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# API metadata
API_VERSION=2.0.0
DEBUG_MODE=false

# Rate limiting
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=1000

# Cache
CACHE_TTL_SECONDS=300

# TikTok request emulation
TIKTOK_USER_AGENT=Mozilla/5.0 (Linux; Android 14; Pixel 8 Pro) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Mobile Safari/537.36
TIKTOK_TIMEOUT_SECONDS=20
TIKTOK_MAX_RETRIES=3

# Streaming
MAX_VIDEO_SIZE_MB=500
STREAM_CHUNK_SIZE_BYTES=1048576

# Logging
LOG_LEVEL=INFO
